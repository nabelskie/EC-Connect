
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ELDERCARE CONNECT SECURITY RULES
     * 
     * Enforces strict Authorization Independence and role-based access control.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the current user is an admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'adminkn@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Checks if the current user is a volunteer
    function isVolunteer() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'volunteer'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Allow any signed-in user to read a profile to see names in chats/requests
      allow get: if isSignedIn();
      // Allow admins to list the whole directory
      allow list: if isAdmin();
      // Users can create/update their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /assistance_requests_pending/{requestId} {
      // Anyone signed in can view pending requests to help out
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      // Allow the creator, admins, or any volunteer to claim/update/delete
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        isAdmin() ||
        isVolunteer()
      );
    }

    match /assistance_requests_active/{requestId} {
      // Allow participants or admins to see and list active requests
      allow get, list: if isSignedIn();
      // Allow volunteers to "create" an active request by accepting it
      allow create: if isSignedIn();
      // Allow participants or admins to update
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        request.auth.uid == resource.data.assignedVolunteerId ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        isAdmin()
      );
    }

    match /assistance_requests_completed/{requestId} {
      allow get, list: if isSignedIn();
      // Move from active to completed
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId} {
      // Allow get/list if user is participant or admin
      // Note: resource is null during creation
      allow get, list: if isSignedIn() && (
        isAdmin() || 
        (resource != null && request.auth.uid in resource.data.participantUserIds)
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId}/messages/{messageId} {
      // Allow participants or admins to read messages
      // Messages denormalize participantUserIds for query efficiency
      allow get, list: if isSignedIn() && (
        isAdmin() ||
        (resource != null && request.auth.uid in resource.data.participantUserIds) ||
        (exists(/databases/$(database)/documents/chat_rooms/$(chatRoomId)) && 
         request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participantUserIds)
      );
      
      // Allow participants to send messages
      allow create: if isSignedIn() && (
        request.resource.data.senderUserId == request.auth.uid && 
        (request.auth.uid in request.resource.data.participantUserIds || isAdmin())
      );
      
      allow update, delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.elderlyUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
