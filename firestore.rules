rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ELDERCARE CONNECT SECURITY RULES
     * 
     * Enforces ownership and relationship-based access control.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || hasRole('admin');
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /assistance_requests_pending/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /assistance_requests_active/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        request.auth.uid == resource.data.assignedVolunteerId
      );
      allow delete: if isSignedIn();
    }

    match /assistance_requests_completed/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /chat_rooms/{chatRoomId} {
      // Allow 'get' for anyone signed in because IDs are unguessable request IDs.
      // This prevents permission errors during document creation/transitions.
      allow get: if isSignedIn();
      
      // Keep 'list' restricted so users can only see their own private inbox.
      allow list: if isSignedIn() && 
        request.auth.uid in resource.data.participantUserIds;
        
      allow create: if isSignedIn();
      allow update: if isSignedIn() && 
        request.auth.uid in resource.data.participantUserIds;
      allow delete: if false;
    }

    match /chat_rooms/{chatRoomId}/messages/{messageId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.elderlyUserId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}