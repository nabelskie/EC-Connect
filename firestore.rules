
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ELDERCARE CONNECT SECURITY RULES
     * 
     * Enforces strict Authorization Independence and role-based access control.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Safely checks if the current user has a specific role.
    function hasRole(role) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      // Check if user is signed in and has admin role doc
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // Allow admins to list the whole directory for management
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /assistance_requests_pending/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      // Allow the creator, admins, or any volunteer (to accept/claim the task) to update/delete
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'volunteer')
      );
    }

    match /assistance_requests_active/{requestId} {
      allow get: if isSignedIn();
      // Allow participants or admins to list
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        request.auth.uid == resource.data.assignedVolunteerId ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        isAdmin()
      );
    }

    match /assistance_requests_completed/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId} {
      // Allow get if document doesn't exist yet (race condition handling) 
      // or if user is participant/admin
      allow get: if isSignedIn() && (
        resource == null || 
        request.auth.uid in resource.data.participantUserIds || 
        isAdmin()
      );
      
      // Allow participants or admins to list chats
      allow list: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || isAdmin()
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId}/messages/{messageId} {
      // Allow participants or admins to read messages
      allow get, list: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || isAdmin()
      );
      
      // Allow participants to send messages
      allow create: if isSignedIn() && (
        request.resource.data.senderUserId == request.auth.uid && 
        (request.auth.uid in request.resource.data.participantUserIds || isAdmin())
      );
      
      allow update, delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.elderlyUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
