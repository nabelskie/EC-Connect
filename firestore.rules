
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ELDERCARE CONNECT SECURITY RULES - Optimized for PKS Environment
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the current user is an admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'adminkn@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Checks if the current user is a volunteer
    function isVolunteer() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'volunteer'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      // Allow list for duplicate matrix check during registration and for admins
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /assistance_requests_pending/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /assistance_requests_active/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /assistance_requests_completed/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId} {
      // Allow read/write if user is a participant
      allow get, list: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid in resource.data.participantUserIds
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId}/messages/{messageId} {
      allow list, get: if isSignedIn();
      
      allow create: if isSignedIn() && (
        request.resource.data.senderUserId == request.auth.uid
      );
      
      allow update, delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
