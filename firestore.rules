rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ELDERCARE CONNECT SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset enforces a strict identity-based and ownership-based model. Access is determined 
     * by comparing the authenticated user's UID against denormalized relationship fields 
     * (e.g., createdByUserId, participantUserIds) stored directly on the documents.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Helper for DBAC - used only when role must be verified globally
    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || hasRole('admin');
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    match /assistance_requests_pending/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.createdByUserId) || isSignedIn()) && request.resource.data.createdByUserId == resource.data.createdByUserId;
      allow delete: if isExistingOwner(resource.data.createdByUserId);
    }

    match /assistance_requests_active/{requestId} {
      allow get, list: if isSignedIn() && (
        (resource.data.keys().hasAll(['createdByUserId']) && request.auth.uid == resource.data.createdByUserId) || 
        (resource.data.keys().hasAll(['assignedVolunteerId']) && request.auth.uid == resource.data.assignedVolunteerId)
      );
      allow create: if isSignedIn() && (request.resource.data.createdByUserId == request.auth.uid || request.resource.data.assignedVolunteerId == request.auth.uid);
      allow update: if resource != null && (request.auth.uid == resource.data.createdByUserId || request.auth.uid == resource.data.assignedVolunteerId);
      allow delete: if resource != null && (request.auth.uid == resource.data.createdByUserId || hasRole('admin'));
    }

    match /assistance_requests_completed/{requestId} {
      allow get, list: if isSignedIn() && (
        (resource.data.keys().hasAll(['createdByUserId']) && request.auth.uid == resource.data.createdByUserId) || 
        (resource.data.keys().hasAll(['assignedVolunteerId']) && request.auth.uid == resource.data.assignedVolunteerId)
      );
      allow create: if isSignedIn() && (request.resource.data.createdByUserId == request.auth.uid || request.resource.data.assignedVolunteerId == request.auth.uid);
      allow update, delete: if false;
    }

    match /chat_rooms/{chatRoomId} {
      allow get, list: if isSignedIn() && 
        resource.data.keys().hasAll(['participantUserIds']) && 
        request.auth.uid in resource.data.participantUserIds;
      allow create: if isSignedIn() && 
        request.resource.data.keys().hasAll(['participantUserIds']) && 
        request.auth.uid in request.resource.data.participantUserIds;
      allow update: if isSignedIn() && 
        resource.data.keys().hasAll(['participantUserIds']) && 
        request.auth.uid in resource.data.participantUserIds && 
        request.resource.data.participantUserIds == resource.data.participantUserIds;
      allow delete: if false;
    }

    match /chat_rooms/{chatRoomId}/messages/{messageId} {
      allow get, list: if isSignedIn() && 
        resource.data.keys().hasAll(['participantUserIds']) && 
        request.auth.uid in resource.data.participantUserIds;
      allow create: if isSignedIn() && 
        request.resource.data.keys().hasAll(['participantUserIds']) && 
        request.auth.uid in request.resource.data.participantUserIds && 
        request.resource.data.senderUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /ratings/{ratingId} {
      allow get, list: if isSignedIn() && (
        (resource.data.keys().hasAll(['elderlyUserId']) && request.auth.uid == resource.data.elderlyUserId) || 
        (resource.data.keys().hasAll(['volunteerUserId']) && request.auth.uid == resource.data.volunteerUserId)
      );
      allow create: if isSignedIn() && request.resource.data.elderlyUserId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}