
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ELDERCARE CONNECT SECURITY RULES
     * 
     * Enforces strict Authorization Independence and role-based access control.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Safely checks if the current user has a specific role.
    function hasRole(role) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /assistance_requests_pending/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.createdByUserId || isAdmin());
    }

    match /assistance_requests_active/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.createdByUserId || 
        request.auth.uid == resource.data.assignedVolunteerId ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.createdByUserId || isAdmin());
    }

    match /assistance_requests_completed/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId} {
      // Allow participants or admins to see chat room details.
      // We allow 'get' if document doesn't exist (resource == null) to handle navigation gracefully 
      // while the volunteer is creating the room document.
      allow get: if isSignedIn() && (
        resource == null || 
        request.auth.uid in resource.data.participantUserIds || 
        isAdmin()
      );
      
      // Queryable Authorization Pattern (QAP) for listing chats
      allow list: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || isAdmin()
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /chat_rooms/{chatRoomId}/messages/{messageId} {
      // READ: Requires query to match the participant filter (Rules are not filters)
      allow get, list: if isSignedIn() && (
        request.auth.uid in resource.data.participantUserIds || isAdmin()
      );
      
      // CREATE: Uses denormalized participantUserIds to evaluate access without parent lookup
      allow create: if isSignedIn() && (
        request.resource.data.senderUserId == request.auth.uid && 
        (request.auth.uid in request.resource.data.participantUserIds || isAdmin())
      );
      
      allow update, delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.elderlyUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
